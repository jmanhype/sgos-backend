# ═══════════════════════════════════════════════════════════════════
# SGOS Backend Environment Configuration
# Copy to .env and fill in your values.
# All variables use SGOS_ prefix (pydantic-settings).
# ═══════════════════════════════════════════════════════════════════

# ─── Auth ────────────────────────────────────────────────────────
# Bearer token for API authentication.
# Leave empty to disable auth (development mode).
SGOS_API_KEY=***

# ─── Database ────────────────────────────────────────────────────
# Path to SQLite database file.
SGOS_DB_PATH=sgos.db

# ─── Uploads ─────────────────────────────────────────────────────
# Maximum file upload size in megabytes.
SGOS_MAX_UPLOAD_MB=100

# ─── LLM Provider ────────────────────────────────────────────────
# The backend uses the same OpenAI-compatible API as the frontend.
# These are read by domain modules (idea_generation, repurpose_engine, etc.)

# API base URL (OpenAI-compatible endpoint)
# OPENAI_BASE_URL=https://dashscope-intl.aliyuncs.com/compatible-mode/v1

# API key for the LLM provider
# OPENAI_API_KEY=***

# Model name (qwen-*, glm-*, gpt-*)
# OPENAI_MODEL=qwen-max

# ─── Ingestion Sources ──────────────────────────────────────────
# Reddit API credentials (optional — falls back to public JSON)
# REDDIT_CLIENT_ID=***
# REDDIT_CLIENT_SECRET=[REDACTED]
# REDDIT_USER_AGENT=sgos-backend/1.0

# Firecrawl API key for deep-scraping (optional)
# FIRECRAWL_API_KEY=***
# FIRECRAWL_URL=http://localhost:3002

# ─── Alerts ──────────────────────────────────────────────────────
# Telegram bot for outlier notifications (optional)
# TELEGRAM_BOT_TOKEN=***
# TELEGRAM_CHAT_ID=***

# ─── Scheduler ───────────────────────────────────────────────────
# Ingestion interval in seconds (default: 14400 = 4 hours)
# SGOS_INGEST_INTERVAL=14400
